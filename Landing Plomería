    <!-- SCRIPT GEOLOCALIZACIÓN MOCKUP -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const geoText = document.getElementById("geo-text");
            
            // Simulamos la detección de ubicación con un timeout para dar efecto real
            setTimeout(() => {
                // En un caso real usarías la API de geolocalización o IP del usuario. 
                // Aquí usamos el dato que me diste: Naucalpan de Juárez
                const zona = "Naucalpan de Juárez";
                const plomerosDisponibles = Math.floor(Math.random() * 3) + 2; // Random 2 a 4
                
                geoText.innerHTML = `📍 ¡<strong>${plomerosDisponibles} plomeros</strong> disponibles ahora mismo cerca de <strong>${zona}</strong>!`;
                
                // Quitamos la animación de pulse una vez cargado
                geoText.parentElement.classList.remove("animate-pulse-soft");
                geoText.parentElement.classList.add("bg-brand-600"); 
            }, 1500);
        });
    </script>
</body>
