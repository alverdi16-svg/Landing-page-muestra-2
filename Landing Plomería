                <span class="font-bold text-xl tracking-tight text-gray-900">Plomeros<span class="text-brand-600">24/7</span></span>
            </div>
            <div class="flex items-center gap-4">
                <div class="hidden md:flex flex-col text-right">
                    <span class="text-xs text-gray-500 font-bold uppercase">Emergencias 24h</span>
