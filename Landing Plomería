                        </li>
                        <li class="flex items-start gap-4">
                            <div class="w-8 h-8 rounded-full bg-brand-100 text-brand-600 font-bold flex items-center justify-center shrink-0 mt-1">2</div>
                            <div>
                                <h4 class="font-bold text-gray-900">Recibe perfiles y cotizaciones</h4>
