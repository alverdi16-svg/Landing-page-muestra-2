                        </h3>
                    </div>
                </a>

            </div>
        </div>
    </section>

    <!-- TRANSPARENCIA DE PRECIOS -->
    <section class="bg-gray-900 text-white py-16">
        <div class="max-w-4xl mx-auto px-4 text-center">
