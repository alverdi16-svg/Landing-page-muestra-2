        .animate-pulse-soft { animation: pulse-soft 2s infinite; }
        
        /* Estilos base para el video/antes-después */
        .video-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; max-width: 100%; border-radius: 0.75rem; }
        .video-container iframe, .video-container img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; }
